<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="640.0"
            prefWidth="980.0"
            styleClass="app-root"
            stylesheets="@styles.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="main.java.BudgetController">

    <top>
        <VBox spacing="14" styleClass="header">
            <padding>
                <Insets top="22" right="26" bottom="20" left="26"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label styleClass="title" text="Spravca rozpoctu"/>
                <Region HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="budgetComboBox" prefWidth="180"/>
                <Button text="Nacitat"
                        styleClass="primary-button"
                        onAction="#handleLoadBudget"/>
            </HBox>

            <HBox spacing="18">
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Label styleClass="stat-label" text="Aktualny rozpocet"/>
                    <Label fx:id="currentBudgetLabel"
                           styleClass="stat-value"
                           text="Nevybrany"/>
                </VBox>

                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Label styleClass="stat-label" text="Pocet poloziek"/>
                    <Label fx:id="itemCountLabel"/>
                </VBox>

                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Label styleClass="stat-label" text="Celkova suma"/>
                    <Label fx:id="totalAmountLabel"
                           styleClass="stat-value"
                           text="0,00 €"/>
                </VBox>
            </HBox>

            <HBox spacing="10">
                <TextField fx:id="nameField"/>
                <TextField fx:id="categoryField"/>
                <TextField fx:id="amountField"/>
                <Button text="Pridať" onAction="#handleAdd"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="12">
            <padding>
                <Insets top="22" right="26" bottom="22" left="26"/>
            </padding>

            <HBox spacing="10">
                <ComboBox fx:id="filterComboBox"/>
                <Button text="Zrušiť filter"
                        onAction="#handleClearFilter"/>
                <Button text="Odobrať"
                        onAction="#handleRemove"/>
            </HBox>

            <TableView fx:id="itemsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="nameColumn"
                                 prefWidth="330"
                                 text="Nazov"/>
                    <TableColumn fx:id="categoryColumn"
                                 prefWidth="260"
                                 text="Kategoria"/>
                    <TableColumn fx:id="amountColumn"
                                 prefWidth="160"
                                 text="Suma"/>
                </columns>

                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>

            <Label fx:id="statusLabel"
                   styleClass="status-label"
                   text=""/>
        </VBox>
    </center>

    <right>
        <VBox spacing="10">
            <padding>
                <Insets top="22" right="26" bottom="22" left="10"/>
            </padding>

            <ListView fx:id="categoryTotalsList"/>
        </VBox>
    </right>

</BorderPane>