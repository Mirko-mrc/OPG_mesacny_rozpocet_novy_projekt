<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane prefHeight="720.0" prefWidth="1080.0" styleClass="app-root" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.java.BudgetController">
    <top>
        <VBox spacing="16" styleClass="header">
            <padding><Insets top="22" right="28" bottom="22" left="28" /></padding>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label styleClass="title" text="Sprava vydavkov" />
                <Region HBox.hgrow="ALWAYS" />
                <ComboBox fx:id="budgetComboBox" prefWidth="190" />
                <Button onAction="#handleLoadBudget" styleClass="primary-button" text="Nacitat" /><Button onAction="#handleSave" text="Ulozit" />
            </HBox>
            <HBox spacing="14">
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS"><Label styleClass="stat-label" text="Aktualny profil" /><Label fx:id="currentBudgetLabel" styleClass="stat-value" text="Nevybrany" /></VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS"><Label styleClass="stat-label" text="Pocet poloziek" /><Label fx:id="itemCountLabel" styleClass="stat-value" text="0" /></VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS"><Label styleClass="stat-label" text="Celkova suma" /><Label fx:id="totalAmountLabel" styleClass="stat-value" text="0,00 â‚¬" /></VBox>
            </HBox>
        </VBox>
    </top>
    <center>
        <GridPane hgap="22" vgap="18" styleClass="core">
            <padding><Insets top="24" right="28" bottom="24" left="28" /></padding>
            <columnConstraints><ColumnConstraints hgrow="ALWAYS" minWidth="520" /><ColumnConstraints hgrow="NEVER" minWidth="290" prefWidth="320" /></columnConstraints>
            <rowConstraints><RowConstraints vgrow="ALWAYS" /></rowConstraints>
            <VBox spacing="12" GridPane.columnIndex="0">
                <HBox alignment="CENTER_LEFT" spacing="10"><Label styleClass="section-title" text="Polozky rozpoctu" /><Region HBox.hgrow="ALWAYS" /><ComboBox fx:id="filterComboBox" prefWidth="190" /><Button onAction="#handleClearFilter" text="Zrusit filter" /></HBox>
                <TableView fx:id="itemsTable" VBox.vgrow="ALWAYS">
                    <columns><TableColumn fx:id="nameColumn" prefWidth="260" text="Nazov" /><TableColumn fx:id="categoryColumn" prefWidth="190" text="Kategoria" /><TableColumn fx:id="amountColumn" prefWidth="140" text="Suma" /></columns>
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                </TableView>
                <HBox alignment="CENTER_LEFT" spacing="10"><Button onAction="#handleRemove" styleClass="danger-button" text="Odstranit vybranu polozku" /><Label fx:id="statusLabel" styleClass="status-label" text="" /></HBox>
            </VBox>
            <VBox spacing="16" styleClass="side-panel" GridPane.columnIndex="1">
                <padding><Insets top="18" right="18" bottom="18" left="18" /></padding>
                <VBox spacing="10"><Label styleClass="section-title" text="Nova polozka" /><TextField fx:id="nameField" promptText="Nazov polozky" /><TextField fx:id="categoryField" promptText="Kategoria" /><TextField fx:id="amountField" promptText="Suma v eurach" /><Button maxWidth="Infinity" onAction="#handleAdd" styleClass="primary-button" text="Pridat polozku" /></VBox>
                <Separator />
                <VBox spacing="10" VBox.vgrow="ALWAYS"><Label styleClass="section-title" text="Sucty podla kategorii" /><ListView fx:id="categoryTotalsList" minHeight="220" VBox.vgrow="ALWAYS" /></VBox>
            </VBox>
        </GridPane>
    </center>
</BorderPane>